{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "electron-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
